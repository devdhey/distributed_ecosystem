<configuration>
  <property>
    <name>mapreduce.framework.name</name>
    <value>yarn</value>
  </property>

  <!-- Definindo o quanto de memoria cada tarefa do map reduce pode usar -->
  <property>
    <name>mapreduce.map.memory-mb</name>
    <value>800</value> <!-- Quantidade de RAM que cada tarefa de mapeamento pode usar -->
  </property>

  <property>
    <name>mapreduce.reduce.memory-mb</name>
    <value>800</value> <!-- Quantidade de RAM que cada tarefa de redução pode usar -->
  </property>

  <property>
    <name>mapreduce.map.java.opts</name>
    <value>-Xmx640m</value> <!-- Opções JVM para tarefas de mapeamento (80% da RAM alocada) -->
  </property> <!-- isso evita erros de memoria fisica -->

  <property>
    <name>mapreduce.reduce.java.opts</name>
    <value>-Xmx640m</value> <!-- Opções JVM para tarefas de redução (80% da RAM alocada) -->
  </property> <!-- isso evita erros de memoria fisica -->
  
</configuration>